# SPID / CIE Service Provider Configuration (Tauri + Companion)

# URL del server companion che gestisce gli scambi SAML 2.0 con gli Identity Provider
VITE_SPID_COMPANION_BACKEND_URL=http://localhost:3000

# Entity ID univoco del nostro Service Provider (registrato presso AgID)
VITE_SPID_ENTITY_ID=https://progettoits.servizidigitali.it

# Ambiente di esecuzione SPID: test (Spid Demo/Local), validator (AgID validator), production (Regole di Produzione)
VITE_SPID_ENVIRONMENT=test

# Endpoint pubblico per esporre l'XML di Metadata SPID firmato
VITE_SPID_METADATA_URL=http://localhost:3000/metadata

# Assertion Consumer Service (ACS) dove l'IdP effettua la POST SAML Response
VITE_SPID_ACS_URL=http://localhost:3000/acs

# Schema URI personalizzato catturato dall'app Tauri per ricevere il token di sessione
VITE_SPID_DEEP_LINK_SCHEME=progettoits://auth
