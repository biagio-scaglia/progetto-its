{
  "name": "progettoits",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:knowledge": "npx tsx scripts/buildKnowledgeIndex.ts",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare": "node -e \"const fs = require('fs'); const dir = 'src/rag'; if (!fs.existsSync(dir)) fs.mkdirSync(dir, {recursive: true}); if (!fs.existsSync(dir + '/knowledge_index.json')) fs.writeFileSync(dir + '/knowledge_index.json', '{\\\"chunks\\\": []}')\""
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
